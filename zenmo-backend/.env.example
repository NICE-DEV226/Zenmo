# Database
MONGO_URI=mongodb+srv://zenmo-admin:your-actual-password@cluster0.mongodb.net/zenmo?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-change-this-in-production
JWT_REFRESH_SECRET=your-very-long-and-secure-refresh-secret-key-change-this-in-production

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (for WebSocket scaling)
REDIS_HOST=localhost
REDIS_PORT=6379

# OneSignal (for push notifications)
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# Environment
NODE_ENV=development
PORT=3000
